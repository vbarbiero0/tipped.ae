# Copy to .env.local and fill in. Without these, the site runs on built-in seed data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=https://tipped.ae

# Telegram alert on new pending submissions (Step 5) — both optional.
# Without them the alert is a silent no-op. Get the token from @BotFather;
# the chat id from the bot's getUpdates after you /start it.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
